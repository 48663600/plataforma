generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  correo    String   @unique
  password  String
  rol       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppState {
  id        Int      @id
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}